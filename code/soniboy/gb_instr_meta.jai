    _0xE8: Json_Opcode_Data; @JsonName(0xE8)
    _0xE9: Json_Opcode_Data; @JsonName(0xE9)
    _0xEA: Json_Opcode_Data; @JsonName(0xEA)
    _0xEB: Json_Opcode_Data; @JsonName(0xEB)
    _0xEC: Json_Opcode_Data; @JsonName(0xEC)
    _0xED: Json_Opcode_Data; @JsonName(0xED)
    _0xEE: Json_Opcode_Data; @JsonName(0xEE)
    _0xEF: Json_Opcode_Data; @JsonName(0xEF)
    _0xF0: Json_Opcode_Data; @JsonName(0xF0)
    _0xF1: Json_Opcode_Data; @JsonName(0xF1)
    _0xF2: Json_Opcode_Data; @JsonName(0xF2)
    _0xF3: Json_Opcode_Data; @JsonName(0xF3)
    _0xF4: Json_Opcode_Data; @JsonName(0xF4)
    _0xF5: Json_Opcode_Data; @JsonName(0xF5)
    _0xF6: Json_Opcode_Data; @JsonName(0xF6)
    _0xF7: Json_Opcode_Data; @JsonName(0xF7)
    _0xF8: Json_Opcode_Data; @JsonName(0xF8)
    _0xF9: Json_Opcode_Data; @JsonName(0xF9)
    _0xFA: Json_Opcode_Data; @JsonName(0xFA)
    _0xFB: Json_Opcode_Data; @JsonName(0xFB)
    _0xFC: Json_Opcode_Data; @JsonName(0xFC)
    _0xFD: Json_Opcode_Data; @JsonName(0xFD)
    _0xFE: Json_Opcode_Data; @JsonName(0xFE)
    _0xFF: Json_Opcode_Data; @JsonName(0xFF)

    #overlay (_0x00) opcodes: [0x100] Json_Opcode_Data;

    Json_Opcode_Data :: struct {
      mnemonic: string;
      bytes: int;
      cycles: [] int;
      operands: [] Json_Operand;
      immediate: bool;
      flags: *JSON_Value;

      Json_Operand :: struct {
        name: string;
        immediate: bool;
        increment: bool;
        decrement: bool;
        bytes: int;
      }
    }
  }

  Json_Instruction_Set :: struct {
    unprefixed: Json_Opcode_Table;
    cbprefixed: Json_Opcode_Table;

    #overlay (unprefixed) set: [2] Json_Opcode_Table;
  };
  unprefixed := NewArray(256, GB_Instruction);
  cbprefixed := NewArray(256, GB_Instruction);
  push_allocator(temp);

  load_result, instrs := json_parse_file(OPCODE_DESCRIPTOR_PATH, Json_Instruction_Set);
  assert (load_result);
  instruction_sets := [] GB_Instruction.[unprefixed, cbprefixed];
  for set, set_index: instrs.set {
    for opcode, opcode_idx: set.opcodes {
      new_instr := *instruction_sets[set_index][opcode_idx];
      new_instr.size = cast(u16) opcode.bytes;
      m_info := type_info(GB_Mnemonic);
      found_mnemonic := false;
      for m_info.names {
        if it == opcode.mnemonic {
          found_mnemonic = true;
          new_instr.mnemonic = cast(GB_Mnemonic) m_info.values[it_index];
        }
      }
      if !found_mnemonic {
        assert(false, "Unrecognized instruction mnemonic: %", opcode.mnemonic);
      }
      op_info := type_info(GB_Operand);

      if opcode.operands.count > 2 {
        assert(new_instr.mnemonic == .LD); // There should only be one...
        new_instr.op1 = .HL;
        new_instr.op2 = .SP_e8;
        continue;
      }

      for * operand, operand_idx: opcode.operands {
        found_operand := false;
        special_operand := false;
        if operand.increment {
          operand.name = sprint("%%", operand.name, "I");
          special_operand = true;
        } else if operand.decrement {
          operand.name = sprint("%%", operand.name, "D");
          special_operand = true;
        } else if !operand.immediate {
          operand.name = sprint("%%", operand.name, "IND");
          special_operand = true;
        }
        for op_info.names {
          if it == operand.name {
            found_operand = true;
            new_instr.op[operand_idx] = cast(GB_Operand) op_info.values[it_index];
          }
        }
        if !found_operand && special_operand then assert(false, "Unrecognized instruction operand: %", operand.name);
        if !found_operand {
          // NOTE: We are probably dealing with an RST vector (0x00, 0x08, 0x10, 0x18, 0x20, 0x28, 0x30, and 0x38),
          // or an unsigned 3-bit integer (u3).
          val, success, _ := string_to_int(advance(operand.name, 1), 16);
          if (success) {
            assert(operand.immediate, "Unhandled special operand: % with opcode: %\n", operand.*, opcode_idx);
            new_instr.op[operand_idx] = .VEC;
            new_instr.vec_or_u3 = cast(u8) val;
          } else {
            val, success, _ = string_to_int(operand.name);
            if (success && operand.name.count == 1) {
              new_instr.op[operand_idx] = .u3;
              new_instr.vec_or_u3 = cast(u8) val;
            } else {
              assert(false, "Unrecognized instruction operand: %", operand.name);
            }
          }
        }
      }
    }
  }

  return unprefixed, cbprefixed;
}

gb_generate_instruction_vtable :: () -> unprefixed: [] gb_instr_proc, prefixed: [] gb_instr_proc {
  result_unprefixed := NewArray(256, gb_instr_proc);
  result_cbprefixed := NewArray(256, gb_instr_proc);
  result_unprefixed[0] = #procedure_of_call gb_instr_nop(null, .NONE, .NONE, 0);
  result_unprefixed[1] = #procedure_of_call gb_instr_ld(null, .BC, .n16, 0);
  result_unprefixed[2] = #procedure_of_call gb_instr_ld(null, .BCIND, .A, 0);
  result_unprefixed[3] = #procedure_of_call gb_instr_inc(null, .BC, .NONE, 0);
  result_unprefixed[4] = #procedure_of_call gb_instr_inc(null, .B, .NONE, 0);
  result_unprefixed[5] = #procedure_of_call gb_instr_dec(null, .B, .NONE, 0);
  result_unprefixed[6] = #procedure_of_call gb_instr_ld(null, .B, .n8, 0);
  result_unprefixed[7] = #procedure_of_call gb_instr_rlca(null, .NONE, .NONE, 0);
  result_unprefixed[8] = #procedure_of_call gb_instr_ld(null, .a16IND, .SP, 0);
  result_unprefixed[9] = #procedure_of_call gb_instr_add(null, .HL, .BC, 0);
  result_unprefixed[10] = #procedure_of_call gb_instr_ld(null, .A, .BCIND, 0);
  result_unprefixed[11] = #procedure_of_call gb_instr_dec(null, .BC, .NONE, 0);
  result_unprefixed[12] = #procedure_of_call gb_instr_inc(null, .C, .NONE, 0);
  result_unprefixed[13] = #procedure_of_call gb_instr_dec(null, .C, .NONE, 0);
  result_unprefixed[14] = #procedure_of_call gb_instr_ld(null, .C, .n8, 0);
  result_unprefixed[15] = #procedure_of_call gb_instr_rrca(null, .NONE, .NONE, 0);
  result_unprefixed[16] = #procedure_of_call gb_instr_stop(null, .n8, .NONE, 0);
  result_unprefixed[17] = #procedure_of_call gb_instr_ld(null, .DE, .n16, 0);
  result_unprefixed[18] = #procedure_of_call gb_instr_ld(null, .DEIND, .A, 0);
  result_unprefixed[19] = #procedure_of_call gb_instr_inc(null, .DE, .NONE, 0);
  result_unprefixed[20] = #procedure_of_call gb_instr_inc(null, .D, .NONE, 0);
